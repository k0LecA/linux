{
  "layer": "top",
  "position": "top",
  "height": 40,
  "spacing": 0, // Set spacing to 0 and handle it via CSS margins instead
  "margin-top": 10,
  "margin-left": 10,
  "margin-right": 10,
  "exclusive": true,
  "gtk-layer-shell": true,
  "passthrough": false,
  "fixed-center": true,
  "modules-left": ["hyprland/workspaces", "hyprland/window"],
  "modules-center": ["mpris"],
  "modules-right": [
    "cpu",
    "memory",
    "pulseaudio",
    "custom/language",
    "clock",
    "tray",
    "custom/notification",
    "battery",
    "custom/power"
  ],
  // ... rest of your module configs (battery, mpris, etc.) remain the same ...
  "battery": {
    "states": { "good": 95, "warning": 30, "critical": 15 },
    "format": "{icon} {capacity}%",
    "format-charging": "󰂄 {capacity}%",
    "format-plugged": " {capacity}%",
    "format-alt": "{icon} {time}",
    "format-icons": ["󰂎", "󰁺", "󰁻", "󰁼", "󰁽", "󰁾", "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"],
    "on-click-right": "brightnessctl s 5%-"
  },
  "tray": { "show-passive-items": true, "icon-size": 18, "spacing": 10 },
  "mpris": {
    "player": "spotify",
    "format": "{player_icon} {artist} - {title}",
    "format-paused": " <i>{artist} - {title}</i>",
    "player-icons": { "default": "", "spotify": "" }
  },
  "hyprland/workspaces": { "on-click": "activate", "format": "{id}" },
  "clock": { "format": "{:%H:%M | %a %d}", "tooltip-format": "<tt>{calendar}</tt>" },
  "cpu": { "format": " {usage}%" },
  "memory": { "format": " {used:0.1f}Gi" },
  "pulseaudio": { "format": "{icon} {volume}%", "format-muted": "", "format-icons": { "default": ["", "", ""] } },
  "custom/language": { "exec": "hyprctl devices -j | jq -r '[.keyboards[] | select(.main == true)] | .[0].active_keymap' | cut -c1-2", "interval": 1, "format": "⌨ {}" },
  "custom/power": { "on-click": "wlogout -p layer-shell &", "format": "⏻" },
  "custom/notification": { "exec": "swaync-client -swb", "return-type": "json", "format": "{icon}", "format-icons": { "none": "󰅺", "notification": "󰡟" }, "on-click": "swaync-client -t -sw" }
}
